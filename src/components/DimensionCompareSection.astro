---
const dimensions = [
  {
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.7 0-3 .9-3 2s1.3 2 3 2 3 .9 3 2-1.3 2-3 2m0-8V6m0 12v-2M4 12a8 8 0 1 1 16 0 8 8 0 0 1-16 0Z"/></svg>',
    iconCls: 'bg-teal/10 text-teal', title: '学费 · 性价比',
    items: [
      { flag: '🇲🇾', label: '马来西亚', rating: '最经济', cls: 'text-jade font-semibold' },
      { flag: '🇯🇵', label: '日本', rating: '较亲民', cls: 'text-ink/60' },
      { flag: '🇰🇷', label: '韩国', rating: '中等 · 奖学金多', cls: 'text-ink/60' },
      { flag: '🇭🇰', label: '香港', rating: '偏高', cls: 'text-amber font-medium' },
      { flag: '🇸🇬', label: '新加坡', rating: '最高', cls: 'text-coral font-medium' },
    ]
  },
  {
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.5 0c-.3 4-2 8-7.5 10M5 9c.5 3 2.5 5 6 6M14 19l4-9 4 9m-7-2h6"/></svg>',
    iconCls: 'bg-coral/12 text-coral', title: '授课语言',
    items: [
      { flag: '🇸🇬', label: '新加坡', rating: '英语', cls: 'text-jade font-semibold' },
      { flag: '🇭🇰', label: '香港', rating: '中英', cls: 'text-jade font-semibold' },
      { flag: '🇲🇾', label: '马来西亚', rating: '英语', cls: 'text-jade font-semibold' },
      { flag: '🇯🇵', label: '日本', rating: '日语为主*', cls: 'text-amber font-medium' },
      { flag: '🇰🇷', label: '韩国', rating: '韩语为主*', cls: 'text-amber font-medium' },
    ],
    footnote: '*日韩均设有部分全英文授课项目（如 SGU/GSIS）。'
  },
  {
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7V5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2m4 0H5a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2Z"/></svg>',
    iconCls: 'bg-amber/15 text-amber', title: '工作 · 留下前景',
    items: [
      { flag: '🇭🇰', label: '香港', rating: '毕业签较友好', cls: 'text-jade font-semibold' },
      { flag: '🇸🇬', label: '新加坡', rating: '机会多 · 门槛高', cls: 'text-ink/60' },
      { flag: '🇯🇵', label: '日本', rating: '就业稳 · 看语言', cls: 'text-ink/60' },
      { flag: '🇰🇷', label: '韩国', rating: '需较强韩语', cls: 'text-amber font-medium' },
      { flag: '🇲🇾', label: '马来西亚', rating: '多作跳板', cls: 'text-ink/60' },
    ]
  },
  {
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21s-7-4.4-9.3-9C1.4 9 2.7 5.5 6 5.5c2 0 3.3 1.3 4 2.5.7-1.2 2-2.5 4-2.5 3.3 0 4.6 3.5 3.3 6.5C19 16.6 12 21 12 21Z"/></svg>',
    iconCls: 'bg-teal/10 text-teal', title: '文化适应度',
    items: [
      { flag: '🇭🇰', label: '香港', rating: '最相近', cls: 'text-jade font-semibold' },
      { flag: '🇲🇾', label: '马来西亚', rating: '华人社群多', cls: 'text-jade font-semibold' },
      { flag: '🇸🇬', label: '新加坡', rating: '华人文化浓', cls: 'text-jade font-semibold' },
      { flag: '🇯🇵', label: '日本', rating: '相近 · 礼仪差异', cls: 'text-ink/60' },
      { flag: '🇰🇷', label: '韩国', rating: '相近 · 节奏快', cls: 'text-ink/60' },
    ]
  },
  {
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7l9-4 9 4-9 4-9-4Zm0 0v6m6 1.5V11m6 0v3.5c0 1.4-2.7 2.5-6 2.5"/></svg>',
    iconCls: 'bg-coral/12 text-coral', title: '申请难度',
    items: [
      { flag: '🇸🇬', label: '新加坡', rating: '竞争激烈', cls: 'text-coral font-medium' },
      { flag: '🇭🇰', label: '香港', rating: '名校较卷', cls: 'text-amber font-medium' },
      { flag: '🇯🇵', label: '日本', rating: '看语言成绩', cls: 'text-ink/60' },
      { flag: '🇰🇷', label: '韩国', rating: '相对友好', cls: 'text-ink/60' },
      { flag: '🇲🇾', label: '马来西亚', rating: '门槛较低', cls: 'text-jade font-semibold' },
    ]
  },
];
---

<section id="compare" class="bg-sand py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-5">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <p class="text-teal font-semibold text-[13px] tracking-wider mb-2">五维度 · 横向拆解</p>
      <h2 class="font-serif font-black text-[30px] md:text-[38px] tracking-tight">按你最在意的维度对比</h2>
      <p class="mt-3 text-ink/55 text-[15px]">不堆数字，只讲差别。每个维度告诉你「哪类人更适合哪里」。</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {dimensions.map(d => (
        <div class="rounded-3xl bg-white border border-black/5 p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class={`h-10 w-10 rounded-xl ${d.iconCls} flex items-center justify-center`}>
              <Fragment set:html={d.icon} />
            </span>
            <h3 class="font-serif font-bold text-[18px]">{d.title}</h3>
          </div>
          <ul class="space-y-2.5 text-[13.5px]">
            {d.items.map(item => (
              <li class="dim-row rounded-lg px-2 py-1.5 flex justify-between">
                <span>{item.flag} {item.label}</span>
                <span class={item.cls}>{item.rating}</span>
              </li>
            ))}
          </ul>
          {d.footnote && <p class="mt-3 text-[11.5px] text-ink/40">{d.footnote}</p>}
        </div>
      ))}

      <!-- Summary CTA -->
      <div class="rounded-3xl bg-gradient-to-br from-teal to-jade text-white p-6 flex flex-col justify-center relative overflow-hidden">
        <div class="absolute -top-10 -left-10 h-32 w-32 rounded-full bg-white/10 blur-xl"></div>
        <h3 class="font-serif font-bold text-[19px] mb-2 relative">没有「最好」，只有「最适合你」</h3>
        <p class="text-[13.5px] text-white/80 leading-relaxed relative mb-4">预算紧→马来；要文凭含金量→新港；想兼顾就业与离家近→香港；偏好文化沉浸→日韩。说说你的情况，让结论更具体。</p>
        <button onclick="openChat()" class="relative inline-flex items-center gap-2 rounded-full bg-white text-teal text-[14px] font-semibold px-5 py-2.5 hover:bg-ink hover:text-white transition w-fit">按我的情况看 →</button>
      </div>
    </div>
  </div>
</section>
