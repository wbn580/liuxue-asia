---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到 · 亚洲留学网" description="抱歉，您访问的页面不存在。">
<main class="max-w-3xl mx-auto px-5 py-32 text-center">
  <h1 class="font-serif font-black text-[48px] md:text-[72px] tracking-tight text-teal mb-4">404</h1>
  <p class="text-ink/60 text-[18px] mb-8">抱歉，这个页面不在我们的对比清单里。</p>
  <a href="/" class="inline-flex items-center gap-2 rounded-full bg-teal text-white text-[15px] font-semibold px-6 py-3 hover:bg-jade transition">
    返回首页重新选目的地 →
  </a>
</main>
</BaseLayout>
